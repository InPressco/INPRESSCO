# .env.example — Copier en .env et remplir les valeurs
# NE JAMAIS COMMITTER .env (il est dans .gitignore)

# === Anthropic Claude ===
ANTHROPIC_API_KEY=sk-ant-...

# === Microsoft Outlook / Graph API (OAuth2 MSAL — client credentials) ===
# Créer une app Azure AD : https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
# Permissions requises : Mail.Read, Mail.ReadWrite, Mail.Send (Application, pas Delegated)
OUTLOOK_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
OUTLOOK_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
OUTLOOK_CLIENT_SECRET=your-client-secret
OUTLOOK_USER_EMAIL=contact@in-pressco.com

# === Dolibarr / Freshprocess ===
DOLIBARR_API_KEY=your-dolibarr-api-key
DOLIBARR_BASE_URL=https://in-pressco.crm.freshprocess.eu/api/index.php

# === Dashboard (optionnel) ===
# N8N_BASE_URL=https://your-n8n-instance.com
# N8N_API_KEY=your-n8n-api-key
